```python id="m6f1zo"
#!/usr/bin/env python3

import os
import time
import subprocess
import evdev

from evdev import InputDevice, list_devices

HOME = os.path.expanduser("~")

VENV = os.path.join(
    HOME,
    "pigato/venv/bin/python3"
)

SOCKET = "/tmp/mpvsocket"

MODES = {

    "KEY_KP1": (
        "NORMAL MODE",
        os.path.join(HOME, "pigato/modes/clean_mode.py")
    ),

    "KEY_KP2": (
        "FX MODE",
        os.path.join(HOME, "pigato/modes/fx_mode.py")
    ),

    "KEY_KP3": (
        "DEV MODE",
        os.path.join(HOME, "pigato/modes/dev_mode.py")
    ),

    "KEY_KP0": (
        "RECOVERY MODE",
        os.path.join(HOME, "pigato/modes/recovery_mode.py")
    ),
}

def find_device():

    for path in list_devices():

        dev = InputDevice(path)

        if dev.name == "Hailuck Co.,Ltd USB KEYBOARD Keyboard":

            return dev

    return None

def kill_all():

    subprocess.call(["pkill", "-f", "clean_mode.py"])
    subprocess.call(["pkill", "-f", "fx_mode.py"])
    subprocess.call(["pkill", "-f", "dev_mode.py"])
    subprocess.call(["pkill", "-f", "recovery_mode.py"])
    subprocess.call(["pkill", "-f", "watchdog.py"])

    subprocess.call(["pkill", "-9", "mpv"])

    time.sleep(1)

    if os.path.exists(SOCKET):

        os.remove(SOCKET)

def start_mpv():

    subprocess.Popen([

        "mpv",

        "--fullscreen",
        "--keep-open=yes",
        "--idle=yes",
        "--loop-file=inf",

        "--input-ipc-server=" + SOCKET,

        "--vo=gpu",
        "--gpu-context=drm",

        "--hwdec=no",

        "--no-audio",

        "--msg-level=all=warn",
    ])

    for _ in range(50):

        if os.path.exists(SOCKET):
            return True

        time.sleep(0.1)

    return False

def start_watchdog():

    subprocess.Popen([
        VENV,
        os.path.join(HOME, "pigato/watchdog.py")
    ])

def start_mode(path):

    subprocess.Popen([
        VENV,
        path
    ])

def main():

    os.system("clear")

    print("\nSEARCHING FOR NUMPAD...\n")

    dev = find_device()

    if not dev:

        print("NUMPAD NOT FOUND")
        return

    print(f"FOUND DEVICE:\n{dev.name}\n")

    print("\n===================================")
    print("         PI-GATO SYSTEM")
    print("===================================\n")

    print("NORMAL MODE   : KP1")
    print("FX MODE       : KP2")
    print("DEV MODE      : KP3")
    print("RECOVERY MODE : KP0\n")

    print("WAITING FOR MODE SELECTION...\n")

    for event in dev.read_loop():

        if event.type != evdev.ecodes.EV_KEY:
            continue

        if event.value != 1:
            continue

        key = evdev.categorize(event).keycode

        if isinstance(key, list):
            key = key[0]

        if key in MODES:

            mode_name, mode_script = MODES[key]

            print(f"\nLAUNCHING {mode_name}...\n")

            kill_all()

            ok = start_mpv()

            if not ok:

                print("MPV FAILED")
                return

            start_watchdog()

            start_mode(mode_script)

            os._exit(0)

if __name__ == "__main__":
    main()
```


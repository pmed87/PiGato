# 11. CREATE GOLDENSCRIPT

Create:

```bash id="f2t6mo"
nano ~/pigato/modes/clean_mode.py
```

Paste:

```python id="h4x8ul"
#!/usr/bin/env python3

import os
import time
import json
import socket
import evdev

from evdev import InputDevice, list_devices

# ==========================================
# CONFIG
# ==========================================

BASE_DIR = os.path.expanduser("~/pigato")

SOCKET_PATH = "/tmp/mpvsocket"

BANKS = ["A", "B", "C", "D", "E"]

current_bank_index = 0

# ==========================================
# CLIP MAP
# ==========================================

KEY_TO_CLIP = {

    "KEY_KP7": "01",
    "KEY_KP8": "02",
    "KEY_KP9": "03",

    "KEY_KP4": "04",
    "KEY_KP5": "05",
    "KEY_KP6": "06",

    "KEY_KP1": "07",
    "KEY_KP2": "08",
    "KEY_KP3": "09",
}

# ==========================================
# FIND NUMPAD
# ==========================================

def find_device():

    for path in list_devices():

        dev = InputDevice(path)

        if dev.name == "Hailuck Co.,Ltd USB KEYBOARD Keyboard":

            return dev

    return None

# ==========================================
# CURRENT BANK
# ==========================================

def current_bank():

    return BANKS[current_bank_index]

# ==========================================
# FIND CLIP
# ==========================================

def find_clip(number):

    path = os.path.join(
        BASE_DIR,
        f"Bank {current_bank()}"
    )

    if not os.path.exists(path):
        return None

    for f in sorted(os.listdir(path)):

        if f.startswith(number) and f.endswith(".mp4"):

            return os.path.join(path, f)

    return None

# ==========================================
# SEND TO MPV
# ==========================================

def send_command(command):

    try:

        s = socket.socket(socket.AF_UNIX)

        s.connect(SOCKET_PATH)

        s.send(
            (json.dumps(command) + "\n").encode()
        )

        s.close()

        return True

    except Exception as e:

        print("\nMPV IPC ERROR")
        print(e)

        return False

# ==========================================
# PLAY CLIP
# ==========================================

def play_clip(path):

    if not path:

        print("\nCLIP NOT FOUND")
        return

    print("\nPLAY:")
    print(os.path.basename(path))

    cmd = {

        "command": [
            "loadfile",
            path,
            "replace"
        ]
    }

    send_command(cmd)

# ==========================================
# SAFETY CLIP
# ==========================================

def play_safety():

    path = os.path.join(
        BASE_DIR,
        "Safety",
        "SafetyClipX.mp4"
    )

    play_clip(path)

# ==========================================
# MAIN
# ==========================================

def main():

    dev = find_device()

    if not dev:

        print("NUMPAD NOT FOUND")
        return

    print("\nPiGATO V11")
    print(f"Device: {dev.name}")
    print(f"Bank: {current_bank()}")

    global current_bank_index

    for event in dev.read_loop():

        if event.type != evdev.ecodes.EV_KEY:
            continue

        if event.value != 1:
            continue

        key = evdev.categorize(event).keycode

        if isinstance(key, list):
            key = key[0]

        # ==================================
        # NEXT BANK
        # ==================================

        if key == "KEY_KPSLASH":

            current_bank_index += 1

            if current_bank_index >= len(BANKS):
                current_bank_index = 0

            print(f"\nBANK {current_bank()}")

            continue

        # ==================================
        # PREVIOUS BANK
        # ==================================

        if key == "KEY_NUMLOCK":

            current_bank_index -= 1

            if current_bank_index < 0:
                current_bank_index = len(BANKS) - 1

            print(f"\nBANK {current_bank()}")

            continue

        # ==================================
        # SAFETY CLIP
        # ==================================

        if key == "KEY_KPASTERISK":

            print("\nSAFETY CLIP")

            play_safety()

            continue

        # ==================================
        # PLAY CLIPS
        # ==================================

        if key in KEY_TO_CLIP:

            clip_num = KEY_TO_CLIP[key]

            path = find_clip(clip_num)

            play_clip(path)

# ==========================================

if __name__ == "__main__":
    main()
```

